# ==========================================
# StartupEvents — Environment Variables
# Copy this file to .env and fill in values
# ==========================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB (use MongoDB Atlas connection string for production)
MONGODB_URI=mongodb://localhost:27017/startupevents

# JWT (change these to strong random secrets in production)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_REFRESH_EXPIRE=30d

# OpenAI (optional — AI features run in mock mode without a key)
OPENAI_API_KEY=

# CORS (only needed if frontend runs on a different origin)
CORS_ORIGIN=http://localhost:3000
