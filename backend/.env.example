# StartupEvents — Environment Variables Template
# Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Get this from MongoDB Atlas (e.g., mongodb+srv://...)
MONGODB_URI=mongodb://localhost:27017/startupevents

# JWT (Set these to long random strings in production)
JWT_SECRET=your_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# CORS
CORS_ORIGIN=http://localhost:3000

# OpenAI (Optional)
# OPENAI_API_KEY=your_openai_api_key
