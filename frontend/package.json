{
  "name": "startupevents-frontend",
  "version": "1.0.0",
  "description": "Frontend for StartupEvents — startup event listing platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
